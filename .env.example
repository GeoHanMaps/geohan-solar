# Google Earth Engine
GEE_PROJECT=geohan-solar
# Service Account JSON path (kalıcı kimlik — boşsa OAuth credentials kullanılır)
# GCP Console → IAM → Service Accounts → Keys → Create JSON key
# Sunucuya kopyala: ~/geohan/geohan-solar/secrets/gee-sa.json (chmod 600)
EE_SERVICE_ACCOUNT_KEY=/app/secrets/gee-sa.json

# API URL'leri
NASA_POWER_URL=https://power.larc.nasa.gov/api/temporal/climatology/point
TCMB_URL=https://www.tcmb.gov.tr/kurlar/today.xml

# Copernicus CAMS (Avrupa/Afrika/Orta Doğu — 3km)
# Kayıt: https://ads.atmosphere.copernicus.eu → Profil → API key
CAMS_ADS_URL=https://ads.atmosphere.copernicus.eu/api
CAMS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# NREL NSRDB (Amerika kıtaları — 4km)
# Kayıt: https://developer.nrel.gov/signup
NSRDB_KEY=your_nrel_api_key_here
NSRDB_EMAIL=your@email.com

# Finansal parametreler
KWH_PRICE_TL=4.20
# YEKA GES-2024 Türkiye referansı: $1.26-1.4M/MW — orta değer
INVESTMENT_PER_MW_USD=1100000
PERFORMANCE_RATIO=0.80

# JWT Auth — python -c "import secrets; print(secrets.token_hex(32))" ile üret
SECRET_KEY=change-me-generate-with-python-secrets
API_USERNAME=admin
API_PASSWORD=change-me-strong-password
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — production'da kendi domain'ini gir (virgülle ayır)
# CORS_ORIGINS=https://geohanmaps.com,https://www.geohanmaps.com
CORS_ORIGINS=*
# Not: * yerine domain listesi kullanıyorsan tırnak içine al: CORS_ORIGINS="https://a.com,https://b.com"

# Heatmap veri dizini
MAPS_DATA_DIR=data/maps

# Claude AI — rapor narratifi + çok dil desteği
# Kayıt: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL (Sprint 9 — kredi sistemi)
# docker-compose.yml zaten postgres servisini kuruyor. Production'da
# POSTGRES_PASSWORD env var'ı `.env`'de set edilmeli; lokal compose
# bağlantısı için DATABASE_URL'i de override etmek isteyebilirsin.
POSTGRES_PASSWORD=change-me-strong-password
# Lokal compose dışında çalıştırmak için (opsiyonel override):
# DATABASE_URL=postgresql+psycopg2://geohan:change-me@localhost:5432/geohan

# Production'da False olmalı (OpenAPI docs kapatır)
DEBUG=false
